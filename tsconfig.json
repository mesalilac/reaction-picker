{
    "compilerOptions": {
        "target": "ES2020",
        "useDefineForClassFields": true,
        "module": "ESNext",
        "lib": [
            "ES2020",
            "DOM",
            "DOM.Iterable"
        ],
        "skipLibCheck": true,
        /* Bundler mode */
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,
        "jsx": "preserve",
        "jsxImportSource": "solid-js",
        /* Linting */
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noFallthroughCasesInSwitch": true,
        "paths": {
            "@/store": [
                "./src/store"
            ],
            "@/bindings": [
                "./src/bindings"
            ],
            "@/utils": [
                "./src/utils"
            ],
            "@/consts": [
                "./src/consts"
            ],
            "@/ui": [
                "./src/ui"
            ],
            "@/components": [
                "./src/components"
            ],
            "@/icons": [
                "./icons"
            ],
            "@/pages": [
                "./src/pages"
            ],
            "@/assets/*": [
                "./src/assets/*"
            ]
        }
    },
    "include": [
        "src"
    ],
    "references": [
        {
            "path": "./tsconfig.node.json"
        }
    ]
}