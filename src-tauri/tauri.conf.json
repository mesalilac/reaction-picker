{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Reaction Picker",
    "version": "0.1.0",
    "identifier": "com.mesalilac.reaction-picker",
    "build": {
        "beforeDevCommand": "pnpm dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "pnpm build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "Reaction Picker",
                "width": 900,
                "height": 600,
                "minWidth": 900,
                "minHeight": 600,
                "center": true,
                "backgroundColor": "#0a0a0a"
            }
        ],
        "security": {
            "csp": null,
            "assetProtocol": {
                "enable": true,
                "scope": [
                    "**"
                ]
            }
        }
    },
    "bundle": {
        "active": true,
        "targets": "msi",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    }
}