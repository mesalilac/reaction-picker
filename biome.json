{
	"$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"linter": {
		"enabled": true,
		"domains": {
			"solid": "all"
		},
		"rules": {
			"recommended": true,
			"correctness": {
				"noUnusedVariables": "warn",
				"noUndeclaredDependencies": "error",
				"noUnresolvedImports": "error",
				"useJsonImportAttributes": "error",
				"noChildrenProp": "error",
				"noConstAssign": "error",
				"noEmptyPattern": "error",
				"noSwitchDeclarations": "error",
				"noUnreachable": "error",
				"noUnsafeFinally": "error"
			},
			"performance": {
				"noAccumulatingSpread": "error"
			},
			"security": {
				"noGlobalEval": "error"
			},
			"style": {
				"noCommonJs": "error",
				"noNamespace": "error",
				"useArrayLiterals": "error",
				"useAsConstAssertion": "error",
				"useBlockStatements": "off",
				"useNamingConvention": "error",
				"noEnum": "error"
			},
			"suspicious": {
				"noDeprecatedImports": "error",
				"noImportCycles": "error",
				"noConsole": {
					"level": "error",
					"options": {
						"allow": [
							"warn",
							"error",
							"debug"
						]
					}
				},
				"noExplicitAny": "error"
			},
			"a11y": {
				"useKeyWithClickEvents": "off"
			},
			"complexity": {
				"noForEach": "error",
				"noCommaOperator": "error",
				"noEmptyTypeParameters": "error",
				"noExtraBooleanCast": "error",
				"noImplicitCoercions": "error",
				"noUselessCatch": "error",
				"noUselessCatchBinding": "error",
				"noUselessContinue": "error",
				"noUselessEmptyExport": "error",
				"noUselessLabel": "error",
				"noUselessLoneBlockStatements": "error",
				"noUselessStringConcat": "error",
				"noUselessSwitchCase": "error",
				"noUselessTernary": "error",
				"noUselessUndefined": "error",
				"noUselessUndefinedInitialization": "error",
				"useArrowFunction": "error",
				"useIndexOf": "error",
				"useLiteralKeys": "error",
				"useOptionalChain": "error",
				"useWhile": "error"
			},
			"nursery": {
				"useFind": "error",
				"useExhaustiveSwitchCases": "error",
				"useDisposables": "error",
				"useAwaitThenable": "error",
				"useArraySortCompare": "error",
				"noUselessTypeConversion": "error",
				"noUnsafePlusOperands": "error",
				"noFloatingPromises": "error",
				"noMisleadingReturnType": "error",
				"noMisusedPromises": "error",
				"noUnnecessaryConditions": "error",
				"useNullishCoalescing": "error",
				"useSortedClasses": {
					"level": "error",
					"fix": "safe",
					"options": {
						"attributes": [
							"classList"
						],
						"functions": [
							"clsx",
							"cn",
							"cva",
							"tw",
							"tw.*"
						]
					}
				}
			}
		}
	},
	"javascript": {
		"formatter": {
			"enabled": true,
			"quoteStyle": "single",
			"jsxQuoteStyle": "single",
			"trailingCommas": "all",
			"semicolons": "always",
			"arrowParentheses": "always",
			"bracketSpacing": true,
			"indentStyle": "space",
			"indentWidth": 4,
			"trailingNewline": true,
			"lineEnding": "lf"
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": {
					"level": "on",
					"options": {
						"groups": [
							":NODE:",
							":BUN:",
							":BLANK_LINE:",
							":PACKAGE_WITH_PROTOCOL:",
							":PACKAGE:",
							":URL:",
							":BLANK_LINE:",
							":ALIAS:",
							":BLANK_LINE:",
							":PATH:",
							":BLANK_LINE:",
							"**/*.css"
						]
					}
				},
				"useSortedAttributes": "on",
				"noDuplicateClasses": "on"
			}
		}
	}
}